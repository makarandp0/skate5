DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skate5
PORT=3000

# Firebase Authentication
# Base64-encoded service account JSON (from Firebase Console > Project Settings > Service Accounts)
FIREBASE_SERVICE_ACCOUNT_BASE64=
# Firebase Web API Key (from Firebase Console > Project Settings > General > Your Apps)
FIREBASE_CLIENT_API_KEY=
# Firebase Web App ID (from Firebase Console > Project Settings > General > Your Apps)
FIREBASE_CLIENT_APP_ID=
# Firebase Auth Domain (optional - defaults to {projectId}.firebaseapp.com)
FIREBASE_AUTH_DOMAIN=
