{
  "name": "skate5",
  "private": true,
  "type": "module",
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prod:up": "docker compose --profile production up -d --build",
    "prod:down": "docker compose --profile production down",
    "dev": "pnpm --filter @skate5/api --filter @skate5/web run dev",
    "dev:api": "pnpm --filter @skate5/api run dev",
    "dev:web": "pnpm --filter @skate5/web run dev",
    "build": "pnpm --filter './packages/*' run build",
    "lint": "eslint packages/",
    "typecheck": "pnpm --filter './packages/*' run typecheck",
    "db:create": "pnpm --filter @skate5/api run db:create",
    "db:migrate": "pnpm --filter @skate5/api run db:migrate",
    "db:import": "tsx scripts/migrate-firebase.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "kysely": "^0.27.6",
    "pg": "^8.13.1",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.21.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "22.14.0",
    "pnpm": "10.34.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@tailwindcss/oxide"]
  }
}
